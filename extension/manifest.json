{
  "manifest_version": 3,
  "name": "RoleTrace AI Autofill",
  "version": "1.0",
  "description": "AI-powered autofill for internship application forms. Works with RoleTrace.",

  "permissions": [
    "sidePanel",
    "activeTab",
    "scripting",
    "tabs"
  ],

  "host_permissions": [
    "https://roletrace.onrender.com/*",
    "http://localhost:8000/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://roletrace.onrender.com/apply*",
        "http://localhost:8000/apply*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "action": {
    "default_title": "RoleTrace AI Autofill",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
